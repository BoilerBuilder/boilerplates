{
  "extends": "./.config/ts/strict.json",
  "compilerOptions": {
    // Incremental build cache — tsc -b reuses this file to skip unchanged files
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    // Path alias: @/ → src/ (e.g. import Button from '@/components/Button')
    "paths": {
      "@/*": ["./src/*"]
    },
    // vite/client           → import.meta.env, import.meta.hot, etc.
    // vitest/globals        → describe, it, expect, vi, etc. without explicit imports
    // @testing-library/jest-dom → toBeInTheDocument(), toHaveValue(), etc.
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
